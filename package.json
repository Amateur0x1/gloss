{
  "name": "gloss",
  "description": "A local-first macOS app for multilingual parallel reading and scholarly passage alignment.",
  "private": true,
  "version": "0.1.0",
  "author": "Amateur0x1",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:preview": "pnpm build && electron .",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip --publish never"
  },
  "build": {
    "appId": "com.amateur0x1.gloss",
    "productName": "Gloss",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.education",
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "Gloss-${version}.${ext}"
    },
    "artifactName": "Gloss-${version}-${arch}.${ext}"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^9.0.4"
  }
}
